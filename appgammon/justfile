default: dev

dev: db-up db-migrate
    pnpm dev

ios: db-up db-migrate
    pnpm --filter server run dev & pnpm --filter mobile run ios & wait

db-up:
    docker compose -f apps/server/docker/docker-compose.yaml up -d
    @echo "Waiting for Postgres to be ready..."
    @until docker exec appgammon-db pg_isready -U appgammon > /dev/null 2>&1; do sleep 0.5; done
    @echo "Postgres is ready."

db-down:
    docker compose -f apps/server/docker/docker-compose.yaml down

db-reset:
    docker compose -f apps/server/docker/docker-compose.yaml down -v
    just db-up db-migrate

db-migrate:
    pnpm --filter server run db:migrate

db-generate:
    pnpm --filter server run db:generate

db-studio:
    pnpm --filter server run db:studio

# Spin up just the server + DB (no mobile app)
sandbox: db-up db-migrate
    pnpm --filter server run dev

# Fresh sandbox: wipe DB, re-migrate, start server
sandbox-fresh: db-reset
    pnpm --filter server run dev

remote: db-up db-migrate
    bash scripts/remote-dev.sh

test:
    pnpm test

typecheck:
    pnpm typecheck

lint:
    pnpm lint
