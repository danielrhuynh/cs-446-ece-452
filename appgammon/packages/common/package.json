{
  "name": "@appgammon/common",
  "version": "1.0.0",
  "private": true,
  "files": [
    "src",
    "dist"
  ],
  "sideEffects": false,
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./gameplay": {
      "types": "./src/gameplay/index.ts",
      "default": "./src/gameplay/index.ts"
    },
    "./types": {
      "types": "./src/types/index.ts",
      "default": "./src/types/index.ts"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "devDependencies": {
    "typescript": "~5.9.2"
  }
}
